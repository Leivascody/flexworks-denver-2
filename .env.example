# Copy this to .env.local for local dev, OR add these as Environment Variables in Vercel.

# Resend API key for sending emails (free tier: 3,000 emails/month)
# Sign up at https://resend.com → API Keys → Create
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Email address to receive investor activity alerts (defaults to info@greenwichstreetcap.com)
GSC_NOTIFY_EMAIL=info@greenwichstreetcap.com

# Mapbox token for interactive maps (free tier: 50k loads/month)
# Sign up at https://mapbox.com → Account → Access Tokens
# Then paste into index.html → window.GSC_CONFIG.MAPBOX_TOKEN
# (Mapbox is loaded client-side, not from these env vars)
